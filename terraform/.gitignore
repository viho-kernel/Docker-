# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files, which are likely to contain sensitive data
*.tfvars
*.tfvars.json

# Ignore override files, as they are usually used to override resources locally
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan files
*.tfplan
tfplan

# Ignore lock files (optional - uncomment to track)
# .terraform.lock.hcl

# IDE and Editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
.env
.env.local

# OS specific files
Thumbs.db
.project
.pydevproject
.settings/
.classpath

# Temporary files
*.tmp
*.temp
*.log
*.bak
*.backup

# Python compiled files
__pycache__/
*.py[cod]
*$py.class

# Backup and lock files
*.backup
*.lock

# Shell script temporary files
*.sh.bak

# macOS specific
.AppleDouble
.LSOverride
._*

# Windows specific
$RECYCLE.BIN/